@using CoffeeShop.BlazorApp.Shared.Navigation
@using CoffeeShop.BlazorApp.Common.Enums
@using CoffeeShop.BlazorApp.Common.Records

<PageTitle>@CurrentPage.ViName - KOPPEE Coffee Shop</PageTitle>

<div class="container-fluid page-header mb-5 position-relative overlay-bottom">
    <div class="d-flex flex-column align-items-center justify-content-center pt-0 pt-lg-5"
         style="min-height: 400px">

        <h1 class="display-4 mb-3 mt-0 mt-lg-5 text-white text-uppercase">
            @CurrentPage.ViName
        </h1>

        <div class="d-inline-flex mb-lg-5">
            <p class="m-0 text-white">
                <a class="text-white" href="@HomePage.Route">
                    @HomePage.ViName
                </a>
            </p>

            <p class="m-0 text-white px-2">/</p>

            <p class="m-0 text-white">
                @CurrentPage.ViName
            </p>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public PageType PageName { get; set; }

    private PageInfo CurrentPage =>
        NavigationPages.Data[PageName];

    private PageInfo HomePage =>
        NavigationPages.Data[PageType.Home];
}